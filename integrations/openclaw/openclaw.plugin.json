{
  "id": "plugin.vmga",
  "name": "VMGA Mail Governance",
  "description": "Route OpenClaw mailbox tools through the VMGA broker.",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "properties": {
      "broker_url": {
        "type": "string",
        "description": "VMGA broker base URL."
      },
      "broker_token": {
        "type": "string",
        "description": "Optional VMGA broker bearer token."
      },
      "broker_timeout_seconds": {
        "type": "number",
        "minimum": 1,
        "maximum": 120
      }
    },
    "additionalProperties": false
  },
  "activation": {
    "onStartup": true
  },
  "contracts": {
    "tools": [
      "mail_search",
      "mail_get",
      "mail_summarize",
      "mail_classify",
      "mail_extract_entities",
      "mail_recommend_draft",
      "mail_get_attachment",
      "mail_create_draft",
      "mail_send",
      "mail_forward",
      "mail_archive",
      "mail_delete",
      "mail_apply_label",
      "mail_mark_read",
      "mail_move"
    ]
  }
}
